{
  "name": "bc-source-mcp",
  "version": "0.1.1",
  "description": "MCP server exposing Business Central source code (all versions and localizations) from MSDyn365BC.Sandbox.Code.History to AI agents.",
  "type": "module",
  "bin": {
    "bc-source-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "business-central",
    "al",
    "dynamics-365",
    "model-context-protocol"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@vscode/ripgrep": "^1.15.9",
    "better-sqlite3": "^11.3.0",
    "pino": "^9.5.0",
    "simple-git": "^3.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  },
  "author": "Gabriel Lachana",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glachana/bc-source-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/glachana/bc-source-mcp/issues"
  },
  "homepage": "https://github.com/glachana/bc-source-mcp#readme"
}
